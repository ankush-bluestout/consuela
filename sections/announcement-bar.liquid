            },
            {
              "value": "background-2",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.color_scheme.options__2.label"
            },
            {
              "value": "inverse",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.color_scheme.options__3.label"
            },
            {
              "value": "accent-1",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.color_scheme.options__4.label"
            },
            {
              "value": "accent-2",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.color_scheme.options__5.label"
            },
            {
              "value": "custom",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.color_scheme.options__6.label"
            }
          ],
          "default": "accent-1",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.color_scheme.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "header",
          "content": "t:sections.announcement-bar.blocks.announcement.settings.color_header.label"
        },
        {
          "type": "color",
          "id": "color_text",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.color_text.label"
        },
        {
          "type": "color",
          "id": "color_bg",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.color_bg.label"
        },
        {
          "type":"header",
          "content": "Custom CSS Rules"
        },
        {
          "type":"paragraph",
          "content": "Explanation of Custom CSS rules below input."
        },
        {
          "type": "html",
          "id": "custom_css",
          "label": "Custom CSS"
        },
        {
          "type":"paragraph",
          "content": "Use '==' to reference this block's parent container, that way the css you use only applies to this container. The example below applies font size to only the h2 element in the current block's container."
        },
        {
          "type":"paragraph",
          "content": "Ex: '== h2 { font-size: 20px; }'"
        },
        {
          "type":"paragraph",
          "content": "Use '/MEDIA_QUERY/' to create media queries that match css defaults. The example below would output '@media screen and (max-width: 749px)' before the css."
        },
        {
          "type":"paragraph",
          "content": "Ex: '/small/ { == h2 { font-size: 20px; } }'"
        },
        {
          "type":"paragraph",
          "content": "Media Queries: narrow, not-narrow, small, medium, medium-up, medium-down, large, large-up, large-down, ex-large, ex-large-up, ex-large-down, widescreen"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
