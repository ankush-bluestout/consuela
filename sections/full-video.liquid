{% if product.metafields.custom.hero_video_1 != blank %}
<div data-section-type="full-video">
  {%- liquid 
    assign mf = product.metafields.custom
    assign vid = mf.hero_video_1
    assign img = mf.hero_video_1_image_fallback
  %}
  {% render 'snippet--video', 
    vidHosted: vid, 
    hostedThumb: img,
    normalMobile: true,
    autoPlay: true
  %}
</div>
{% endif %}
{% style %}
  .video-inline video {
    width: 100%;
    height: 100vh;
    object-fit: cover;
  }
  [data-section-type="full-video"] .jw-aspect {
    padding-top: 100vh!important;
  }
  [data-section-type="full-video"] .jw-media video {
    object-fit: cover!important;
  }
{% endstyle %}

{% schema %}
{
  "name": "Full video section",
  "settings": [
    
  ],
  "presets": [
    {
      "category": "video",
      "name":"Full video section"
    }
  ]
}
{% endschema %}