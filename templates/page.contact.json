    "166256936411277fb9": {
      "type": "nine15--custom-html",
      "settings": {
        "title": "",
        "custom_html": "{% capture lnks %}\n  Contact Us == #form1\n  Order Status == #order-status\n  Ordering & Payment == #ordering\n  Shipping Information == #shipping\n  Returns & Exchanges == #returns\n  Buy Now, Pay Later == #buy-now\n{% endcapture %}\n\n{% liquid\n assign lnks = lnks | newline_to_br | split: '<br />' \n assign foundFirst = false\n%}\n\n<div class=\"page-width\">\n  <div class=\"tabs small--hide\">\n    <div class=\"tabs-scroll\">\n      {% for l in lnks %}\n        {% liquid\n          assign splt = '=='\n          assign parts = l | split: splt\n        %}\n        {% if parts[0] != blank and parts[1] != blank %}\n          <a class=\"tab-trig {% if foundFirst == false %}current{% endif %}\" href=\"{{-parts[1]|trim|strip-}}\">\n            {{parts[0]}}\n          </a>\n          {% capture opts %}\n            {{opts}}\n            <option value=\"{{-parts[1]|trim|strip-}}\">\n              {{parts[0]}}\n            </option>\n          {% endcapture %}\n          {% assign foundFirst = true %}\n        {% endif %}\n      {% endfor %}\n    </div>\n  </div>\n  <div class=\"select medium-up--hide\">\n    <select class=\"select__select\" id=\"contactScroll\" onchange=\"scrollToEl(this)\">\n      {{opts}}\n    </select>\n    {% render 'icon-caret' %}\n  </div>\n  <script type=\"text/javascript\"></script>\n</div>\n\n<script type=\"text/javascript\">\n  function scrollToEl(el) {\n    simulateClick(document.querySelector('[href=\"'+el.value+'\"]'))\n  }\n  var simulateClick = function (elem) {\n    // Create our event (with options)\n    var evt = new MouseEvent('click', {\n      bubbles: true,\n      cancelable: true,\n      view: window\n    });\n    // If cancelled, don't dispatch our event\n    var canceled = !elem.dispatchEvent(evt);\n  };\n  document.addEventListener('DOMContentLoaded', function () {\n    var inViewLinks  = document.querySelectorAll('#shopify-section-{{section.id}} .tab-trig');\n    if ( inViewLinks != null ) {\n      inViewLinks.forEach(function (link) {\n        elementInView(link)\n      });\n      function elementInView(link) {\n        var linkTo = link.getAttribute(\"href\").trim().replace('#',''),\n            linkedSection = document.getElementById(linkTo);\n        if ( linkedSection != null ) {\n          window.addEventListener(\"scroll\", function() {\n            var inViewOffset      = window.outerHeight * 0.25,\n                inViewClass       = 'current',\n                isInView          = window.scrollY > (linkedSection.offsetTop - inViewOffset),\n                isFirst           = link => [link.parentNode.children].findIndex(c => c == link),\n                hasClass          = link.classList.contains(inViewClass);\n            if ( isInView && !hasClass) {\n              link.parentElement.querySelectorAll('.'+inViewClass).forEach(sib => sib.classList.remove(inViewClass))\n              link.classList.add(inViewClass);\n            }\n            if (!isInView && hasClass) {\n              // link.classList.remove(inViewClass);\n            }\n          });\n        }\n      }\n    }\n  })\n</script>",
        "custom_css": "#shopify-section-{{section.id}} {\n  position: sticky;\n  top: 0;\n  background: white;\n  z-index: 10;\n  padding: var(--base-gutter--quarter) 0;\n  border-bottom: 1px solid RGBA(var(--color--shuttle-gray-rgb),0.1);\n}\n\n\n.header-sticky #shopify-section-{{section.id}} {\n  top: calc(var(--header-height--total) - 1px);\n}\n\n== .tabs-scroll {\n  justify-content: center;\n}"
      }
    },
