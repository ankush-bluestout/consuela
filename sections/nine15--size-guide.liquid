                        "id": "tags",
                        "label": "Only show for Vendor items with Tags (optional)",
                        "info": "One Per Line. Type exactly as it appears in Product Admin. If left blank then will show on all Products with Vendor.",
                        "placeholder": "Boys\nBlue\nBubbles"
                    },{% endcomment %}


