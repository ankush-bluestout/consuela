    "1662563199bdc9b317": {
      "type": "nine15--ctas",
      "settings": {
        "title": "BUY NOW, PAY LATER",
        "text": "<p><b>Installments By {% render 'icon-afterpay' %} <span class=\"visually-hidden\">AfterPay</span> and {% render 'icon-klarna' %} <span class=\"visually-hidden\">Klarna</span></b></p>\n\n<ol>\n  <li>Pick your items and select Afterpay or Klarna as your payment method in checkout.</li>\n  <li>No credit-check, wait period, or long forms required! Your order will ship as soon as it’s processed by Consuela.</li>\n  <li>You’ll receive your order within the same timeframe as any regular order with no interest, no additional fees when you pay on time.</li>\n</ol>\n\n<p><b>VIEW ORDERS & MAKE PAYMENTS ANYTIME</b></p>\n\n<p>After your order is processed by the store, you can log in to your account to view your orders, make payments, and manage your account details.</p>\n\n</div>{% comment %}Using this to close the code-side \".rte\" container. Prevents incorrect button styling.{% endcomment %}\n\n<div class=\"btn-container\">\n  <a href=\"https://portal.afterpay.com/us/login-email\" class=\"btn button button--secondary\">\n    <span>Access your</span>\n    {% render 'icon-afterpay' %}\n    <span class=\"visually-hidden\">AfterPay</span>\n    <span>Account</span>\n  </a>\n  <a href=\"https://app.klarna.com/login\" class=\"btn button button--secondary\">\n    <span>Access your</span>\n    {% render 'icon-klarna' %}\n    <span class=\"visually-hidden\">Klarna</span>\n    <span>Account</span>\n  </a>\n</div>",
        "link_text": "",
        "link_url": "",
