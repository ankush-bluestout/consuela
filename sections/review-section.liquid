            <clipPath id="clip0_5018_694">
              <rect width="19.2157" height="11.6667" fill="white" transform="translate(8.39944e-07 19.2157) rotate(-90)"/>
            </clipPath>
          </defs>
        </svg>
      </button>
    </div>
    <div class="reviews-slider-viewport">
      <div class="reviews-slider">
        {% for block in section.blocks %}
          <div class="review-slide" {{ block.shopify_attributes }}>
            <div class="review-left">
              {% if block.settings.product_image != blank %}
                <a href="{{ block.settings.image_link | default: '#' }}">
                  <img
                    src="{{ block.settings.product_image | image_url: width: 900 }}"
                    alt="{{ block.settings.product_title }}"
                    loading="lazy"
                    width=""
                    height=""
                  >
                </a>
              {% endif %}
            </div>

            <div class="review-right">
              <div class="review-top">
                <div class="review_top_one">
                  <a href="{{ block.settings.button_link | default: '#' }}" class="btns">
                    <h3>{{ block.settings.product_title }}</h3>
                  </a>
                  {% if block.settings.price != blank %}
                    <h4>{{ block.settings.price }}</h4>
                  {% endif %}
                  <div class="stars">
                    {% for i in (1..block.settings.stars) %}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="21" viewBox="0 0 20 21" fill="none">
                        <path d="M9.98493 2.67578L11.7919 8.52864H17.6389L12.9078 12.1472L14.7148 18.0001L9.98493 14.3828L5.25382 18.0001L7.06083 12.1472L2.33093 8.52864H8.17792L9.98493 2.67578Z" fill="black" stroke="black" stroke-width="1.57878"/>
                      </svg>
                    {% endfor %}
                  </div>
                </div>
              </div>
              <a href="{{ block.settings.button_link | default: '#' }}" class="btns">
                <div class="review-text">"
                  {{ block.settings.quote }}"
                  <span class="review-name">
                    {{ block.settings.name }}
                  </span>
                </div>
              </a>
              {% if block.settings.name != blank %}
              {% endif %}
              <div class="review-bottom">
                <a href="{{ block.settings.button_link | default: '#' }}" class="shop-btn">
                  {{ block.settings.button_label }}
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    padding: 60px 13px;
    max-width: 100% !important;
  }

  .review_top_one {
    display: grid;
    grid-template-columns: auto auto;
  }


  .review_top_one h4{
    margin-left: 84px;
  }

  .reviews-header {
    margin-bottom: 0px;
    display: flex;
    justify-content: space-between;
  }

  .reviews-header img {
    cursor: pointer;
  }

  .subtitle {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #000;
    text-transform: uppercase;
    margin: 0px 30px;
    font-family: var(--font--graphik-wide);
  }

  .subtitle span {
    display: block;
    font-size: 96px;
    font-family: var(--font--graphik-cond);
    line-height: 1;
  }

  .reviews-slider-wrapper {
    margin: 0px 30px;
    display: flex;
    align-items: center;
  }

  .reviews-slider-viewport {
    overflow: hidden;
    width: 100%;
  }

  .reviews-slider {
    display: flex;
    transition: transform 0.5s ease;
  }

  .review-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
  }

  .review-left img {
    display: block;
    margin-left: 60px;
    max-width: 420px;
  }

  .review-right {
    flex: 1;
  }

  .review-top {
    display: flex;
    gap: 84px;
  }

  .review-top h3,h4 {
    font-family: var(--font--graphik-wide);
    font-size: 15px;
    font-weight: 700;
    color: #000;
    text-align: center;
    font-feature-settings: 'liga' off, 'clig' off;
    font-style: normal;
    font-weight: 700;
    line-height: 22px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 0px;
    margin-bottom: 9px;
  }

  .review-top h4 {
    font-size: 16px;
  }

  .review-text {
    margin: 33px 0 52px 0px;
    font-size: 28px;
    font-weight: 500;
    max-width: 97%;
  }


  .review-bottom {
    display: flex;
    align-items: center;
    font-family: var(--font--graphik-wide);
    gap: 89%;
  }

  .shop-btn {
    padding: 16px 24px;
    background: #000;
    color: #fff;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .btns {
    text-decoration: none;
  }

  .arrow {
    transform: translateY(-50%);
    background: #fff;
    border: none;
    cursor: pointer;
    padding: 11px 16px 12px 18px;
    position: absolute;
    border-radius: 50px;
    box-shadow: 0 0 4px rgba(0,0,0,0.1);
    z-index: 2;
  }

  .mobile_svg {
    display: none;
  }

  .prev { left: 40px; }
  .next { right: 40px; }

  .btn_groups {
    margin-top: 85px;
  }

  .review_top_one h4 {
    display: none !important;
  }

  @media (min-width: 768px) {
    .review-right {
      padding-left: 20px !important;
    }
  }

  @media (max-width: 860px) {
    .btn_groups {
      margin-top: -350px;
    }
  }
 
  @media (max-width: 425px) {

    .prev {
      left: 20px;
    }

    .next {
      right: 20px;
    }
  }

  .play_btn {
    display: none;
  }

  .play_btn.clicked {
    display: flex;
  }

  @media (max-width: 425px) {
  .play_btn.clicked {
    display: none !important;
  }
  }

  .pause_btn.clicked {
    display: none
  }

  @media (max-width: 1024px) {
    .review-slide {
      flex-direction: column;
      text-align: center;
    }

      .review_top_one {
      grid-template-columns: auto;
      margin: auto;
      max-width: 99%;
    }

    .review_top_one h4{
    margin-left: 0px;
    }

    .review-text {
      margin: auto;
      margin-top: 33px;
      margin-bottom: 52px;
    }

    .review-bottom {
      max-width: 90%;
      margin: auto;
      justify-content: center;
    }
  }

  @media (max-width: 3840px) {
  .review-bottom {
    gap: 75%;
  }
  }

  @media (max-width: 2560px) {
   .review-text  {
      max-width : 80%;
    }
  }

  @media (max-width: 1920px) {
    .review-bottom {
      gap: 77%;
    }

    .review-text {
      max-width: 93%;
    }
  }

  @media (max-width: 1920px) {
    .review-bottom {
          max-width: 98%;
      gap: 64%;
    }
  }

  @media (max-width: 1280px) {
    .review-bottom {
      gap: 350px;
    }
  }
  @media (max-width: 820px) {
    .review-bottom {
      flex-direction: column;
      gap: 20px;
    }

    .btn_group {
      display: none;
    }

    .review-left img {
      margin-left: 0px;
    }

    .review-text {
      font-size: 20px;
      margin-left: 0px;
      margin-right: 0px;
    }

    .subtitle span {
    font-size: 11.8vw;
   }

   .reviews-header img {
     display: none;
   }

     .reviews-header {
      display: block;
      text-align: center;
      margin-bottom: 25px;
    }
  }

  @media (max-width: 860px) {
    .review-left img {
      margin-left: 0px;
    }


  }

  @media (max-width: 640px) {
    .subtitle span {
      font-size: 11.8vw;
    }

    .review-left img {
      margin-left: 0px;
      max-width: 220px;
    }

    .review-top h3, h4 {
      font-size: 13px;
      font-weight: 600;
    }

    .review-text {
     font-size: 16px;
     font-weight: 400;
     line-height: 20px;
    }

    .arrow svg {
      display: none;
    }

    .mobile_svg {
      display: flex !important;
    }

    .reviews-slider-wrapper {
      margin: 0px 22px;
    }

    .review-text {
      max-width: 100%;
      margin-top: 13px;
      margin-bottom: 0;
    }

    .reviews-section {
      padding: 25px 0px;
    }

    .shop-btn {
      font-weight: 700;
    }

    .subtitle {
      margin: 0px;
    }

    .review-top h4 {
      font-size: 13px;
    }

    .reviews-header {
      margin-bottom: 0;
    }

    .review-name {
      color: #000;
      text-align: center;
      font-family: 'Graphik Wide Web';
      font-size: 12px;
      font-weight: 600;
      line-height: 30.6px; /* 255% */
      letter-spacing: 0.36px;
      margin: 0 0 10px;
      display: block;
    }
  }

  @media (max-width: 389px) {
    .review-left img {
      max-width: 140px;
      margin-bottom: 5px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const slider = document.querySelector('.reviews-slider');
  const viewport = document.querySelector('.reviews-slider-viewport');
  const slides = document.querySelectorAll('.review-slide');
  const next = document.querySelector('.next');
  const prev = document.querySelector('.prev');

  const pauseBtn = document.querySelector('.pause_btn');
  const playBtn = document.querySelector('.play_btn');

  if (!slider || !viewport || slides.length === 0) return;

  const speed = {{ section.settings.scroll_speed }} * 1000;

  let interval = null;
  let isAutoScrolling = false;

  /* -----------------------
  CREATE CLONES
  ----------------------- */

  const firstClone = slides[0].cloneNode(true);
  const lastClone = slides[slides.length - 1].cloneNode(true);

  slider.appendChild(firstClone);
  slider.insertBefore(lastClone, slides[0]);

  const allSlides = document.querySelectorAll('.review-slide');

  let index = 1; // start on real first slide
  const total = allSlides.length;

  /* -----------------------
  SLIDER POSITION
  ----------------------- */

  function updateSlider(animate = true) {

    const slideWidth = viewport.offsetWidth;

    if (!animate) {
      slider.style.transition = "none";
    } else {
      slider.style.transition = "transform 0.5s ease";
    }

    slider.style.transform = `translateX(-${index * slideWidth}px)`;
  }

  /* -----------------------
  NEXT
  ----------------------- */

  function nextSlide() {

    if (index >= total - 1) return;

    index++;
    updateSlider();

  }

  /* -----------------------
  PREV
  ----------------------- */

  function prevSlide() {

    if (index <= 0) return;

    index--;
    updateSlider();

  }

  /* -----------------------
  RESET WHEN HITTING CLONES
  ----------------------- */

  slider.addEventListener('transitionend', () => {

    if (allSlides[index] === firstClone) {

      slider.style.transition = "none";
      index = 1;
      updateSlider(false);

    }

    if (allSlides[index] === lastClone) {

      slider.style.transition = "none";
      index = total - 2;
      updateSlider(false);

    }

  });

  /* -----------------------
  AUTOSCROLL
  ----------------------- */

  function startAutoScroll() {

    if (!isAutoScrolling && total > 1) {

      interval = setInterval(nextSlide, speed);
      isAutoScrolling = true;
      updateButtons();

    }

  }

  function stopAutoScroll() {

    clearInterval(interval);
    interval = null;
    isAutoScrolling = false;
    updateButtons();

  }

  function toggleAutoScroll() {

    if (isAutoScrolling) {
      stopAutoScroll();
    } else {
      startAutoScroll();
    }

  }

  /* -----------------------
  BUTTON UI
  ----------------------- */

  function updateButtons() {

    if (!pauseBtn || !playBtn) return;

    if (isAutoScrolling) {

      pauseBtn.classList.remove('clicked');
      playBtn.classList.remove('clicked');

    } else {

      pauseBtn.classList.add('clicked');
      playBtn.classList.add('clicked');

    }

  }

  /* -----------------------
  EVENTS
  ----------------------- */

  next?.addEventListener('click', () => {

  const wasAutoScrolling = isAutoScrolling;

  stopAutoScroll();
  nextSlide();

  if (wasAutoScrolling) {
    startAutoScroll();
  }

});

prev?.addEventListener('click', () => {

  const wasAutoScrolling = isAutoScrolling;

  stopAutoScroll();
  prevSlide();

  if (wasAutoScrolling) {
    startAutoScroll();
  }

});

  pauseBtn?.addEventListener('click', toggleAutoScroll);
  playBtn?.addEventListener('click', toggleAutoScroll);

  window.addEventListener('resize', () => updateSlider(false));

  /* -----------------------
  SWIPE
  ----------------------- */

  let startX = 0;

  viewport.addEventListener('touchstart', e => {
    startX = e.touches[0].clientX;
  });

  viewport.addEventListener('touchend', e => {

    let diff = e.changedTouches[0].clientX - startX;

    if (diff > 50) prevSlide();
    if (diff < -50) nextSlide();

  });

  /* -----------------------
  INIT
  ----------------------- */

  updateSlider(false);

  {% if section.settings.auto_scroll %}
    startAutoScroll();
  {% else %}
    updateButtons();
  {% endif %}

});
</script>
