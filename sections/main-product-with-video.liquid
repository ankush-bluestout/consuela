    <script>

      document.addEventListener("DOMContentLoaded", ()=>{
        const addToCartButton = document.querySelector('[data-type="add-to-cart-form"]');

       if(!addToCartButton.querySelector('.klaviyo-bis-trigger')) {
        const cartIcon = document.querySelector('[href="/cart"]');
  
        addToCartButton.addEventListener("click", ()=>{
          setTimeout(()=>{
            cartIcon.click();
          }, 2000)
        })
      
      }
     })

      document.addEventListener('DOMContentLoaded', ()=>{

        const mobileZoomButton = document.querySelector(".mobile-zoom-button");
        const mobileZoomPopup = document.querySelector('.mobile-zoom-popup');
        if(mobileZoomButton) {
          mobileZoomButton.addEventListener("click", ()=>{
            mobileZoomPopup.classList.remove('hidden')
            document.body.style.overflow = 'hidden'
          })
        }

        
        const interval = setInterval(()=>{
          var details = document.querySelectorAll('.product__info-container .description .content_inner .heading')
          if(details.length >= 2){
            console.log("details", details)
            {% comment %} details[details.length - 1].querySelector('strong').click(); {% endcomment %}

            clearInterval(interval);
          }
        }, 1000)
      })
        const tags = {{ tags | json }};

      tags.forEach((item, index)=>{
        if(item == "discontinued"){
          document.querySelector('.product-form__buttons .product-form__submit').disabled = true;
          document.querySelector('.product-form__buttons').classList.add('hidden-element');
          document.querySelector('.freeshipping_note').classList.add('hidden-element');
        }
      })

            window.addEventListener('resize', function(){
        if(window.innerWidth > 480){
          breadcrumbs_top();
        }
      })

      if(window.innerWidth > 480){
        breadcrumbs_top();
      }

      function breadcrumbs_top(){
        if(document.querySelector('.breadcrumbs.eci-breadcrumbs').offsetHeight > 40){
          document.querySelector('.template--product .main-product--container').classList.add('margin-mobile')
        }
        else{
          document.querySelector('.template--product .main-product--container').classList.add('margin-desktop')
        }
      }
         
      /* START - SCROLLABLE MEDIA FOR DESKTOP */
      document.addEventListener("DOMContentLoaded", function () {
        const thumbnailCells = document.querySelectorAll('.thumbnail-gallery .gallery-cell');
          thumbnailCells.forEach(function (thumbnail) {
            thumbnail.addEventListener('click', function () {
              const mediaId = thumbnail.getAttribute('data-media-id');
              const mainGalleryCell = document.querySelector(`.main-gallery .gallery-cell[data-media-id="${mediaId}"]`);
              if (mainGalleryCell) {
                mainGalleryCell.scrollIntoView({
                  behavior: 'smooth',
                  block: 'center'
                });
              }
            });
          });
        });
      /* END - SCROLLABLE MEDIA FOR DESKTOP */

  document.addEventListener('DOMContentLoaded', function() {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');
      return (msie > 0 || trident > 0);
    }

    // Only run this if it's IE, otherwise, we don't want to mess with the DOM
    if (!isIE()) return;

    const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
    const noscriptTag = document.querySelector('.product-form__noscript-wrapper-{{ section.id }}');
    const variantSwitcher = document.querySelector('variant-radios[data-section="{{ section.id }}"]') || document.querySelector('variant-selects[data-section="{{ section.id }}"]');

    if (noscriptTag && variantSwitcher) {
      // FIX: Use .innerHTML instead of .textContent to ensure the browser 
      // parses the string back into actual HTML elements.
      const noScriptHTML = noscriptTag.innerHTML; 
      variantSwitcher.insertAdjacentHTML('afterend', noScriptHTML);
      variantSwitcher.remove();

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function(event) {
        hiddenInput.value = event.currentTarget.value;
      });
    }
  });
    </script>

