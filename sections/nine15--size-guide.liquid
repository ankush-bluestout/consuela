{% schema %}
    {
        "name": "Size Guides - NINE15",
        "class": "section--size-guides",
        "settings": [
            {
                "type":"text",
                "id":"title",
                "label":"Title"
            },
            {
                "type":"richtext",
                "id":"text",
                "label":"Text"
            },
            {
                "type":"header",
                "content": "Custom CSS Rules"
            },
            {
                "type":"paragraph",
                "content": "Explanation of Custom CSS rules below input."
            },
            {
                "type": "liquid",
                "id": "custom_css",
                "label": "Custom CSS"
            },
            {
                "type":"paragraph",
                "content": "Use '==' to reference this block's parent container, that way the css you use only applies to this container. The example below applies font size to only the h2 element in the current block's container."
            },
            {
                "type":"paragraph",
                "content": "Ex: '== h2 { font-size: 20px; }'"
            },
            {
                "type":"paragraph",
                "content": "Use '/MEDIA_QUERY/' to create media queries that match css defaults. The example below would output '@media screen and (max-width: 749px)' before the css."
            },
            {
                "type":"paragraph",
                "content": "Ex: '/small/ { == h2 { font-size: 20px; } }'"
            },
            {
                "type":"paragraph",
                "content": "Media Queries: narrow, not-narrow, small, medium, medium-up, medium-down, large, large-up, large-down, ex-large, ex-large-up, ex-large-down, widescreen"
            }
        ],
        "max_blocks": 200,
        "blocks": [
            {
                "type": "title",
                "name": "Title Info",
                "settings": [
                    {
                        "type": "header",
                        "content": "Block Type: Title Block"
                    },
                    {
                        "type": "header",
                        "content": "Assign to settings"
                    },
                    {
                        "type": "text",
                        "id": "title",
                        "label": "Tab Title",
                        "placeholder": "Standard Size Guide",
                        "info": "This is only for giving a title in Theme Editor"
                    },
                    {
                        "type": "text",
                        "id": "vendor",
                        "label": "Assign to Group",
                        "placeholder": "Standard"
                    },
                    {
                        "type": "header",
                        "content": "Title / Header Content"
                    },
                    {
                        "type": "text",
                        "id": "main_title",
                        "label": "Title for Size Guide",
                        "placeholder": "Classic Whimsy Size Chart",
                        "info": "Appears above tables"
                    },
                    {
                        "type": "image_picker",
                        "id": "main_image",
                        "label": "Image for Size Guide",
                        "info": "Appears above tables"
                    }, 
                    {
                        "type": "richtext",
                        "id": "main_text",
                        "label": "Text for Size Guide",
                        "info": "Appears above tables"
                    }, 
                    {
                        "type": "richtext",
                        "id": "bot_text",
                        "label": "Bottom Text for Size Guide",
                        "info": "Appears below tables"
                    }, 
                    {
                        "type": "text",
                        "id": "table_title",
                        "label": "Title for header row",
                        "placeholder": "Girls",
                        "info": "Appears in header row of table"
                    }, 
                    {
                        "type": "html",
                        "id": "column_titles",
                        "label": "Title for columns",
                        "placeholder": "3M\n6M\n9m",
                        "info": "One title per line"
                    }
                ]
            },
            {
                "type": "row",
                "name": "Row Info",
                "settings": [
                    {
                        "type": "header",
                        "content": "Block Type: Row Block"
                    },
                    {
                        "type": "header",
                        "content": "Assign to settings"
                    },
                    {
                        "type": "text",
                        "id": "title",
                        "label": "Tab Title",
                        "placeholder": "Standard - 16mm",
                        "info": "This is only for giving a title in Theme Editor"
                    },
                    {
                        "type": "text",
                        "id": "vendor",
                        "label": "Assign to Group",
                        "placeholder": "Standard"
                    },
                    {
                        "type": "header",
                        "content": "Row Content"
                    },
                    {
                        "type": "text",
                        "id": "row_title",
                        "label": "Row Title",
                        "placeholder": "1 PC Swimsuit",
                        "info": "Appears above tables"
                    },
                    {
                        "type": "html",
                        "id": "column_info",
                        "label": "Info for columns",
                        "placeholder": "13-13.5in.\n13-14.5in.\nBLANK\n14-14.5in.",
                        "info": "One input per line. Type 'BLANK' to leave empty spot."
                    }
                ]
            }
        ],
        "presets": [
            {
                "name": "Size Guides - NINE15",
                "category": "2 - NINE15"
            }
        ]
    }
{% endschema %}
