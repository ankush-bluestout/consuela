    {
      "type": "paragraph",
      "content":"At Top / Black Text only applies to Overlay Headers."
    },
    {
      "type": "liquid",
      "id": "desktop_at_top_black_text",
      "label": "At Top / Black Text (desktop)."
    },
    {
      "type": "paragraph",
      "content":"If using Overlay Header, then 'At Top / Black Background (desktop)' only applies when hovered."
    },
    {
      "type": "liquid",
      "id": "desktop_at_top_black_bg",
      "label": "At Top / Black Background (desktop)."
    },
    {
      "type": "liquid",
      "id": "desktop_on_scroll_black_bg",
      "label": "On Scroll / Black Background (desktop)"
    },


