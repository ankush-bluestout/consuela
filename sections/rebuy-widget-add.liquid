<div class="master-rebuy-widget">
  <div class="master-rebuy-widget-names">
    {% for block in section.blocks %}
      {% if block.settings.show_title == true %}
        <button class="master-rebuy-widget-name-item {% if forloop.index == 1 %} widget-button-active {% endif %}">{{ block.settings.rebuy_name }}</button>
      {% endif %}
    {% endfor %}
  </div>
  <div class="master-rebuy-widget-contents">
    {% for block in section.blocks %}
      <div class="master-rebuy-widget-content-main master-rebuy-widget-content-item">
        <div data-rebuy-id="{{ block.settings.id }}" data-rebuy-shopify-product-ids="{{ product.id }}"></div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  var buttons = document.querySelectorAll('.master-rebuy-widget-name-item');
  var divs = document.querySelectorAll('.master-rebuy-widget-content-main');

  buttons.forEach((button, index)=>{
    button.addEventListener('click', function(){
      divs.forEach((div, indiv)=>{
        div.classList.add('widget-content-active')
      })
      buttons.forEach((bu, inbu)=>{
        bu.classList.remove("widget-button-active")
      })
      buttons[index].classList.add("widget-button-active");
      divs[index].classList.remove('widget-content-active')
    })
  })

        document.addEventListener("DOMContentLoaded", function() {
            var targetNode = document.querySelector('.master-rebuy-widget-contents')
            var config = { childList: true, subtree: true };
    
            var callback = function(mutationsList, observer) {
              for (var mutation of mutationsList) {
                  if (mutation.type === 'childList') {
                    var divs = document.querySelectorAll('#rebuy-widget-154344 .rebuy-product-block');

                    if(divs.length > 0){
                      divs.forEach((item, index)=>{
                        if(item.querySelector('.rebuy-product-options')){
                          var url = item.querySelector('.rebuy-product-media a').href
                          var product_id = url.split('?')[0].split('/')[4]
                          
                          function getProductImage(productId){
                              fetch(`/products/${productId}.js`)
                              .then(response => response.json())
                              .then(product => {
                                const images = product.images;
                                console.log("imgessssssss",images[0])
                                item.querySelector('.rebuy-product-media a img').src = images[0];
                                console.log('sdjfskfjslkfjlskf', product.metafields)
                              })
                              .catch(error => {
                                console.error('Error fetching product images:', error);
                              });
                          }

                          getProductImage(product_id)
                        }
                      })

                      divs.forEach((item, index)=>{
                        var href = item.querySelector('.rebuy-product-media a').href;
                        item.querySelector('.rebuy-product-actions').innerHTML = '<a class="rebuy-button" href="'+ href +'">View Details</a>'
                      })
                      
                      observer.disconnect();
                      break;
                    }
                      
                }
              }
            }

            var observer = new MutationObserver(callback);
            observer.observe(targetNode, config);
        });

