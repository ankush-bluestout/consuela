    <!-- AGI: Review Schema Code: START: Added 4/30/2024 -->
    <script type="application/ld+json" id="agi-product-schema"></script>

    <script>
      var agi_product_color = '';
      {% if product.metafields.custom.filter_color %}
        {% for color in product.metafields.custom.filter_color.value %}
          agi_product_color +="{{color}}"+"/";
          {% endfor %}
        agi_product_color = agi_product_color.slice(0,-1);
      {% endif %}

      // console.log(agi_product_color);
      var _agiSchemaObj = {
        "@context": "http://schema.org/",
        "@type": "Product",
        "name": {{ product.title | json }},
        "url": {{ request.origin | append: product.url | json }},
        {% if seo_media -%}
          "image": [
            {{ seo_media | image_url: width: seo_media.preview_image.width | prepend: "https:" | json }}
          ],
        {%- endif %}
        "description": {{ product.description | strip_html | json }},
        {% if product.selected_or_first_available_variant.sku != blank -%}
          "sku": {{ product.selected_or_first_available_variant.sku | json }},
        {%- endif %}
        "brand": {
          "@type": "Brand",
          "name": {{ product.vendor | json }}
        },
        "offers": [
          {%- for variant in product.variants -%}
            {
              "@type" : "Offer",
              {%- if variant.sku != blank -%}
                "sku": {{ variant.sku | json }},
              {%- endif -%}
              {%- if variant.barcode.size == 12 -%}
                "gtin12": {{ variant.barcode }},
              {%- endif -%}
              {%- if variant.barcode.size == 13 -%}
                "gtin13": {{ variant.barcode }},
              {%- endif -%}
              {%- if variant.barcode.size == 14 -%}
                "gtin14": {{ variant.barcode }},
              {%- endif -%}
              "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
              "price" : {{ variant.price | divided_by: 100.00 | json }},
              "priceCurrency" : {{ cart.currency.iso_code | json }},
              "url" : {{ request.origin | append: variant.url | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
          {% if product.metafields.custom.filter_color %}
        ,"color":agi_product_color
          {% endif %}
      };

      var agi_review_data = [];

      var agi_checkForReviewCount = 0;
      var agi_chekForReview = setInterval(function() {
          // console.log("AGI: Checking For Review");
          if (document.querySelectorAll('div[class="stamped-review"]').length) {
              clearInterval(agi_chekForReview);

              agi_review_flag = true;

              var agi_review_author = "";
              var agi_review_rating = "";
              var agi_review_date = "";
              var agi_review_title = "";
              var agi_review_body = "";

              if (document.querySelectorAll('div[class="stamped-review"]').length > 0) {

                  document.querySelectorAll('div[class="stamped-review"]').forEach(function(reviewNode) {

                      // Author
                      agi_review_author = reviewNode.querySelectorAll('strong[class="author"]')[0].innerText;

                      // Rating
                      agi_review_rating = reviewNode.querySelectorAll('.stamped-fa-star').length;

                      // Date
                      agi_review_date = reviewNode.querySelectorAll('div.created')[0].innerText;

                      // Title
                      agi_review_title = reviewNode.querySelectorAll('.stamped-review-header-title')[0].innerText;

                      // Body
                      agi_review_body = reviewNode.querySelectorAll('.stamped-review-content-body')[0].innerText;

                      agi_review_data.push({
                          "@type": "Review",
                          "author": {
                              "@type": "Person",
                              "name": agi_review_author
                          },
                          "datePublished": agi_review_date,
                          "reviewBody": agi_review_body,
                          "name": agi_review_title,
                          "reviewRating": {
                              "@type": "Rating",
                              "bestRating": "5",
                              "ratingValue": agi_review_rating,
                              "worstRating": "1"
                          }
                      });

                  });
              }

              // console.log("AGI: Review Data", agi_review_data);

              _agiSchemaObj["review"] = agi_review_data;

              _agiSchemaObj["aggregateRating"] = {
                            "@type": "AggregateRating",
                            "ratingValue": document.querySelectorAll('.stamped-summary-caption span')[0].getAttribute("data-rating"),
                            "reviewCount": document.querySelectorAll('.stamped-summary-caption span')[0].getAttribute("data-count")
                          }
              // console.log("AGI: Schema Data", JSON.stringify(_agiSchemaObj));

              document.querySelector('#agi-product-schema').innerText = JSON.stringify(_agiSchemaObj);
          } else {
              if (agi_checkForReviewCount == 250) {
                  clearInterval(agi_chekForReview);
                  document.querySelector('#agi-product-schema').innerText = JSON.stringify(_agiSchemaObj);
              }
              agi_checkForReviewCount++;
          }
      }, 10);
    </script>
    <!-- AGI: Review Schema Code: END: Added 4/30/2024 -->
  </section>
</div>

