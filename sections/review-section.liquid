{% schema %}
{
  "name": "Scrolling Reviews",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "OVER 25,000 FIVE STAR REVIEWS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "WHAT PEOPLE ARE SAYING"
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Enable Auto Scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Auto Scroll Speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "product_image", "label": "Product Image" },
        { "type": "url", "id": "image_link", "label": "Image Link" },
        { "type": "text", "id": "product_title", "label": "Product Title" },
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "price", "label": "Price" },
        { "type": "textarea", "id": "quote", "label": "Quote / Description" },
        { "type": "text", "id": "name", "label": "Reviewer Name" },
        { "type": "text", "id": "position", "label": "Reviewer Position / Location" },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "SHOP NOW" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [{ "name": "Scrolling Reviews" }]
}
{% endschema %}

<section class="reviews-section page-width">
  <div class="reviews-header">
    <div>
      <h2 class="subtitle">
        {{ section.settings.subtitle }}
        <span>{{ section.settings.title }}</span>
      </h2>
    </div>
    <div style="margin-right: 37px;" class="btn_group">
      <img src="{{ 'btn.svg' | asset_url }}" alt="Button Icon" width="" height="" class="pause_btn">
      <img src="{{ 'button-play.svg' | asset_url }}" alt="Button Icon" width="" height="" class="play_btn">
    </div>
  </div>

  <div class="reviews-slider-wrapper">
    <div class="btn_groups">
