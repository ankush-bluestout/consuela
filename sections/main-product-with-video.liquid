      //   if (!colorsWrapper || !mainSection) return;

      //   const setHeight = () => {
      //     const height = colorsWrapper.offsetHeight + 25;
      //     mainSection.style.setProperty('--colors-height', height + 'px');
      //   };

      //   // Run on initial load
      //   window.addEventListener('load', setHeight);

      //   // Optimized resize (debounced)
      //   let resizeTimer;
      //   window.addEventListener('resize', () => {
      //     clearTimeout(resizeTimer);
      //     resizeTimer = setTimeout(setHeight, 100);
      //   });
      // })();
      (function () {
          const colorsWrapper = document.querySelector('[data-colors-wrapper]');
          const mainSection = document.querySelector('[data-main-pdp-section]');

          // If elements are missing, set the variable to 0px
          if (!colorsWrapper || !mainSection) {
              if (mainSection) {
                  mainSection.style.setProperty('--colors-height', '10px');
              }
              return;
          }

          const setHeight = () => {
              const height = colorsWrapper.offsetHeight + 0;
              mainSection.style.setProperty('--colors-height', height + 'px');
          };

          // Run on initial load
          window.addEventListener('load', setHeight);

          // Optimized resize (debounced)
          let resizeTimer;
          window.addEventListener('resize', () => {
              clearTimeout(resizeTimer);
              resizeTimer = setTimeout(setHeight, 100);
          });
      })();
    </script>
