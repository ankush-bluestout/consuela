{% if template.suffix == 'james-avery' %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const labels = document.querySelectorAll('label');
      // Select your square-placement element
      const placement = document.querySelector('#placement-1763759292387');

      if (placement) {
        labels.forEach((label) => {
          label.addEventListener('click', () => {
            placement.style.display = 'block'; // Force it to display
          });
        });
      }
      const targetSelector = 'square-placement';
      const elename = document.querySelector('.form__label').innerText;
      const mainObserver = new MutationObserver((mutations, mainObs) => {
        const el = document.querySelector(targetSelector);
        if (el && el.shadowRoot) {
          injectStyle(el.shadowRoot);
          const shadowObserver = new MutationObserver(() => {
            if (!el.shadowRoot.querySelector('style[data-custom-style]')) {
              injectStyle(el.shadowRoot);
            }
          });
          shadowObserver.observe(el.shadowRoot, { childList: true, subtree: true });
          mainObs.disconnect();
        }
      });

      mainObserver.observe(document.body, { childList: true, subtree: true });
      function injectStyle(shadowRoot) {
        const style = document.createElement('style');
        const style1 = document.createElement('style');
        style.dataset.customStyle = 'true';
        style1.dataset.customStyle = 'true';
        style1.textContent = `
    @media (max-width: 425px) {
        .afterpay-logo-link {
          display: none !important;
        }

        .afterpay-main-text {
          font-size: 13px !important;
          top: 0px;
        }

        .afterpay-paragraph {
          position: absolute;
          margin-top: calc(166px + var(--colors-height)) !important;
        }
      }

      @media (max-width: 375px) {
        .afterpay-main-text {
          bottom: 70% !important;
        }
        
        .afterpay-paragraph {
          margin-top: calc(175px + var(--colors-height)) !important;
        }

      }
      @media (max-width: 364px) {
        .afterpay-main-text {
          font-size: 12px !important;
        }
      }
    `;
        style.textContent = `
      @media (max-width: 425px) {
        .afterpay-logo-link {
          display: none !important;
        }

        .afterpay-main-text {
          font-size: 13px !important;
