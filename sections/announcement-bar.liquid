<!-- sections/announcement-bar -->

{% liquid

  assign s            = section.settings
  assign sID          = section.id

  assign customCSS    = s.custom_css
  
  assign sectionClass = 'section--' | append: sID
  assign cssClass     = '.' | append: sectionClass

  assign lnkTxt_1     = s.link_text_1
  assign lnkUrl_1     = s.link_url_1
  assign el_1         = 'div'
  assign attr_1       = ''
  if lnkUrl_1 != blank
      assign el_1     = 'a'
      assign attr_1   = 'href="' | append: lnkUrl_1 | append: '"'
  endif  

  assign lnkTxt_2     = s.link_text_2
  assign lnkUrl_2     = s.link_url_2
  assign el_2         = 'div'
  assign attr_2       = ''
  if lnkUrl_2 != blank
      assign el_2     = 'a'
      assign attr_2   = 'href="' | append: lnkUrl_2 | append: '"'
  endif  

%}

{% style %}
  .announcement-bar__container .announcement-bar__side-link{
      height: 25px;
      display: flex;
  }

  .announcement-bar__container .announcement-bar__side-link .social-nav{
    height: 100%;
    width: 100%;
    display: flex;
    gap: 10px;
    padding-left: 20px;
  }

  .announcement-bar__container .announcement-bar__side-link .social-nav a{
    height: 100%;
    margin: 0px 8px;
    align-items: center;
    width: 24px;
  }
{% endstyle %}

{% if section.blocks.size > 0 %}
  {% include 'custom-css', css: customCSS, class: cssClass %}
  <div class="announcement-bar__container {{sectionClass}}">
    <div class="">
      <div class="announcement-bar__slider">
        {%- for block in section.blocks -%}
          {% liquid
            assign b            = block.settings
            assign bID          = block.id
            assign txt          = b.text
            assign lnk          = b.link
            assign clr          = b.color_scheme
            assign clrTxt       = b.color_text
            assign clrBg        = b.color_bg
            assign customCSS    = b.custom_css
            assign blockClass   = 'block--' | append: bID
            assign cssClass     = '.' | append: blockClass
          %}
          <div class="announcement-bar color-{{ clr }} gradient {{blockClass}}" role="region" aria-label="{{ 'sections.header.announcement' | t }}" {{ block.shopify_attributes }}>
  
            <div class="page-width">
              
              {% if lnkTxt_1 != blank %}
                <{{el_1}} {{attr_1}} class="announcement-bar__side-link small--hide">
                  <span>{{lnkTxt_1}}</span>
                </{{el_1}}>
              {% endif %}

              <div class="announcement-bar__side-link small--hide">
                {% include 'snippet--social-icons' %}
              </div>

              {%- if txt != blank -%}
                {%- if lnk != blank -%}
                  <a href="{{ lnk }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
                {%- endif -%}
                    <p class="announcement-bar__message">
                      {{ txt }}
                      {% comment %}
                      {%- if lnk != blank -%}
                        {% render 'icon-arrow' %}
                      {%- endif -%}
                      {% endcomment %}
                    </p>
                    <style>
                      @media screen and (max-width: 374px) {
                          .announcement-bar {
                            height: 45px;
                          }
                      }
                    </style>
                {%- if lnk != blank -%}
                  </a>
                {%- endif -%}
                {% if clrBg != blank or clrBg != blank %}
                  <style type="text/css">
                    {{cssClass}} {
                      {% if clrTxt != blank %}
                      --color-foreground: {{clrTxt}};
                      {% endif %}
                      {% if clrBg != blank %}
                      --gradient-background: {{clrBg}};
                      --color-base-background-1: {{clrBg}};
                      {% endif %}
                    }
                    {{cssClass}} * {
                      {% if clrTxt != blank %}
                      --color-foreground: {{clrTxt}};
                      color: var(--color-foreground);
                      {% endif %}
                    }
                  </style>
                {% endif %}
                {% include 'custom-css', css: customCSS, class: cssClass %}
              {%- endif -%}
              {% if lnkTxt_2 != blank %}
                <{{el_2}} {{attr_2}} class="announcement-bar__side-link small--hide">
                  <span>{{lnkTxt_2}}</span>
                </{{el_2}}>
              {% endif %}
            
            </div>

          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
  <script type="text/javascript">
    // watch announcement bar to add class
    class ClassWatcher {
      constructor(targetNode, classToWatch, classAddedCallback, classRemovedCallback) {
        this.targetNode = targetNode
        this.classToWatch = classToWatch
        this.classAddedCallback = classAddedCallback
        this.classRemovedCallback = classRemovedCallback
        this.observer = null
        this.lastClassState = targetNode.classList.contains(this.classToWatch)
        this.init()
      }
      init() {
        this.observer = new MutationObserver(this.mutationCallback)
        this.observe()
      }
      observe() {
        this.observer.observe(this.targetNode, { attributes: true })
      }
      disconnect() {
        this.observer.disconnect()
      }
      mutationCallback = mutationsList => {
        for (let mutation of mutationsList) {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            let currentClassState = mutation.target.classList.contains(this.classToWatch)
            if (this.lastClassState !== currentClassState) {
              this.lastClassState = currentClassState
              if (currentClassState) {
                this.classAddedCallback()
              } else {
                this.classRemovedCallback()
              }
            }
          }
        }
      }
    }

    // slider
    {% if section.blocks.size > 1 %}
      waitFor_jQuery(function () {
        $(document).ready(function () {
          $('.announcement-bar__slider').slick({
            infinite: true,
            autoplay: true,
            autoplaySpeed: 4000,
            dots: false,
            arrows: false,
            rows: 0
          })
          .on('beforeChange', function(event, slick, currentSlide, nextSlide){
            updateHeightVar('#shopify-section-announcement-bar .slick-active + .slick-slide','--announce-height');
          });

          updateHeightVar('#shopify-section-announcement-bar .slick-active','--announce-height');

          function workOnClassAdd() {
            $('.announcement-bar__slider').slick('slickPause');
          }
          function workOnClassRemoval() {
            $('.announcement-bar__slider').slick('slickPlay');
          }
          // watch for a specific class change
          let watchEl = document.querySelector('.announcement-bar__slider');
          let classWatcher = new ClassWatcher(watchEl, 'pause', workOnClassAdd, workOnClassRemoval)

        });
      });
    {% endif %}
  </script>
{% endif %}

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "class":"no-overflow",
  "max_blocks": 12,
  "settings": [
    {
      "type":"header",
      "content": "Top links"
    },
    {
      "type": "text",
      "id": "link_text_1",
      "label": "Link Text - 1"
    },
    {
      "type": "url",
      "id": "link_url_1",
      "label": "Link Url - 1"
    },
    {
      "type": "text",
      "id": "link_text_2",
      "label": "Link Text - 2"
    },
    {
      "type": "url",
      "id": "link_url_2",
      "label": "Link Url - 2"
    },
    {
      "type":"header",
      "content": "Custom CSS Rules"
    },
    {
      "type":"paragraph",
      "content": "Explanation of Custom CSS rules below input."
    },
    {
      "type": "liquid",
      "id": "custom_css",
      "label": "Custom CSS"
    },
    {
      "type":"paragraph",
      "content": "Use '==' to reference this block's parent container, that way the css you use only applies to this container. The example below applies font size to only the h2 element in the current block's container."
    },
    {
      "type":"paragraph",
      "content": "Ex: '== h2 { font-size: 20px; }'"
    },
    {
      "type":"paragraph",
      "content": "Use '/MEDIA_QUERY/' to create media queries that match css defaults. The example below would output '@media screen and (max-width: 749px)' before the css."
    },
    {
      "type":"paragraph",
      "content": "Ex: '/small/ { == h2 { font-size: 20px; } }'"
    },
    {
      "type":"paragraph",
      "content": "Media Queries: narrow, not-narrow, small, medium, medium-up, medium-down, large, large-up, large-down, ex-large, ex-large-up, ex-large-down, widescreen"
