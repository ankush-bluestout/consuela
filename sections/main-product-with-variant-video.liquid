    <script>

     document.addEventListener("DOMContentLoaded", ()=>{
        const addToCartButton = document.querySelector('[data-type="add-to-cart-form"]');

       if(!addToCartButton.querySelector('.klaviyo-bis-trigger')) {
        const cartIcon = document.querySelector('[href="/cart"]');
  
        addToCartButton.addEventListener("click", ()=>{
          setTimeout(()=>{
            cartIcon.click();
          }, 2000)
        })
      
      }
     })

      document.addEventListener('DOMContentLoaded', ()=>{
        const mobileZoomButton = document.querySelector(".mobile-zoom-button");
        const mobileZoomPopup = document.querySelector('.mobile-zoom-popup');
        if(mobileZoomButton) {
          mobileZoomButton.addEventListener("click", ()=>{
            mobileZoomPopup.classList.remove('hidden')
            document.body.style.overflow = 'hidden'
          })
        }
        const interval = setInterval(()=>{
          var details = document.querySelectorAll('.product__info-container .description .content_inner .heading')
          if(details.length >= 2){
            console.log("details", details)
            {% comment %} details[details.length - 1].querySelector('strong').click(); {% endcomment %}

            clearInterval(interval);
          }
        }, 1000)
      })

      document.addEventListener("DOMContentLoaded", function () {

        let mainSwiper, thumbsSwiper;

        var state = true;

        var number = {{ section.settings.first_video_order | json }}
        var number2 = {{ section.settings.second_video_order | json }}
        number = parseInt(number)
        number2 = parseInt(number2)

        function initializeSwipers() {
          thumbsSwiper = new Swiper(".thumbs-slider", {
              direction: "vertical",
              slidesPerView: 5,
              spaceBetween: 10,
              loop: false,
              watchSlidesProgress: true,
              watchSlidesVisibility: true,
              slideToClickedSlide: true,
              navigation: {
                  nextEl: ".swiper-button-next"
              },
          });

          mainSwiper = new Swiper(".main-slider", {
              slidesPerView: 1,
              spaceBetween: 10,
              loop: true,
              // thumbs: {
              //     swiper: thumbsSwiper,
              // },
              pagination: {
                  el: '.swiper-pagination', // Target pagination element
                  clickable: true, // Allows users to click on pagination bullets
              },
              navigation: {
                  nextEl: '.swiper-button-next',
                  prevEl: '.swiper-button-prev'
              }
          });

          thumbsSwiper.slideTo(0)
          mainSwiper.slideTo(0)
        }

        initializeSwipers();


        var variants = document.querySelectorAll('.form__variants label');

        variants.forEach((item, index)=>{
          item.addEventListener('click', ()=>{

            thumbsSwiper.slideTo(0)
            mainSwiper.slideTo(0)
            
            var input = document.querySelectorAll('.form__variants input')[index].value;

            document.querySelectorAll('product-gallery-component .swiper-container .swiper-slide.featrued').forEach((it, num)=>{
              it.remove();
            })

            document.querySelectorAll('product-gallery-component .swiper-container-thumbs .swiper-slide.variants-image').forEach((variant, num)=>{
              variant.querySelectorAll('.image--outer').forEach((it, n)=>{
                if(it.querySelector('img').alt == input) {
                  it.classList.remove('hidden');
                }
                else {
                  it.classList.add('hidden')
                }
              })
            })

            document.querySelectorAll('product-gallery-component .swiper-container-main .swiper-slide.variants-image').forEach((variant, num)=>{
              variant.querySelectorAll('.image--outer').forEach((it, n)=>{
                if(it.querySelector('img').alt == input) {
                  it.classList.remove('hidden');
                }
                else {
                  it.classList.add('hidden')
                }
              })
            })

              const container = document.querySelector('product-gallery-component .swiper-container-main .swiper-wrapper');
              const elements = Array.from(document.querySelectorAll("product-gallery-component .swiper-slide[data-swiper-slide-index]"));
              elements.sort((a, b) => a.getAttribute("data-swiper-slide-index") - b.getAttribute("data-swiper-slide-index"));
              elements.forEach(el => container.appendChild(el));
              thumbsSwiper.destroy()
              mainSwiper.destroy()
              console.log(number, number2)

              if (state == true) {
                  var k = 4;
                  if(number2 >= number) {
                    k = 5;
                  }
                    if(number > 1 && number < 4) {
                      var move_to_element =  document.querySelectorAll('product-gallery-component .swiper-container-main .swiper-slide:not(.second-video)')[number - 1]
                      console.log('sdkfjskf', move_to_element)
