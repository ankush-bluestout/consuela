<!-- snippets/master--ctas -->

<style>
  @media (max-width: 749px) {
    .hide-mobile {
      display: none !important;  
    }
  }
</style>

{% liquid 

    assign s                    = section.settings
    assign sID                  = section.id

    assign sectionCustomCSS     = s.custom_css
    assign class                = 'section--' | append: sID
    assign cssClass             = '.' | append: class

    assign blks                 = section.blocks.size

    assign ctaItems             = ''
    assign secTtl               = s.title
    assign secTxt               = s.text
    assign imgIC                = s.icon_image
    assign imgBG                = s.image

    assign imgBG_CF             = false 
    if s.metafield_background_image != blank 
      assign imgBG              = s.metafield_background_image
      assign imgBG_CF           = true 
    endif 

    assign btn_url              = s.button_url
    assign btn_txt              = s.button_text
    assign btnStyle             = s.btn_style

    assign use_btn              = false
    if btn_url != blank and btn_txt != blank
        assign use_btn          = true
    endif

    assign lnk_url              = s.link_url
    assign lnk_txt              = s.link_text
    assign use_lnk              = false
    if lnk_url != blank and lnk_txt != blank
        assign use_lnk          = true
    endif
    
    assign align_boxes_left     = s.align_boxes_left
    assign large_images         = s.large_images
    assign matchRow             = s.match_row

    assign inlineCTAs           = ''
    if s.inline_ctas == true 
        assign inlineCTAs       = 'inline-ctas'
    endif

    assign largeImages          = ''
    if large_images == true 
        assign largeImages      = 'large-images'
    endif

    assign modalFound           = false

    assign clrTxt               = s.text_color
    assign clrBG                = s.gradient

    assign useSlider            = s.use_slider
    assign useSliderMob         = s.use_slider_mobile_only
    assign useOffset            = s.use_offset
    assign useArrows            = s.use_arrows
    assign useDots              = s.use_dots
    assign autoSlide            = s.auto_slide
    assign infinite             = s.infinite

    assign perRow               = s.per_row
    if perRow == 0
        assign perRow           = section.blocks.size
    endif         

    case perRow
        when 1  
            assign width    = ''
            assign max      = 1
        when 2 
            assign width    = 'medium-up--one-half'
            assign max      = 2
        when 3  
            assign width    = 'medium-up--one-third'
            assign max      = 3
        when 5 or 9 or 10 
            assign width    = 'medium--one-third large-up--one-fifth'
            assign max      = 5
        when 6 or 11 or 12 
            assign width    = 'medium--one-third large-up--one-sixth'
            assign max      = 6
        when 7 
            assign width    = 'medium--one-third large-up--one-seventh'
            assign max      = 7
        when 8 
            assign width    = 'medium--one-third large-up--one-eighth'
            assign max      = 8
        else  
            assign width    = 'medium-up--one-quarter'
            assign max      = 4
    endcase 

    
%}

