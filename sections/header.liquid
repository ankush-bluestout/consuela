<!-- sections/header -->

<link rel="stylesheet" href="{{ 'custom-nav.scss.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'custom-nav.scss.css' | asset_url | stylesheet_tag }}</noscript>

{% liquid

  assign s                = section.settings
  assign sID              = section.id

  assign customCSS        = s.custom_css
  
  assign sectionClass     = 'section--' | append: sID
  assign cssClass         = '.' | append: sectionClass

  assign leftMenu         = s.menu
  assign rightMenu        = s.right_menu
  assign mobMenu          = s.menu_mob | default: leftMenu

  assign sideMenu        = s.menu_sidepanel

  assign image_size       = s.logo_width | append: 'x'

  assign hdrTxt           = s.text_color
  assign hdrBG            = s.gradient
  assign hdrTopTxt        = s.top_text_color
  assign hdrTopBG         = s.top_gradient

%}

{% liquid 

  assign curPage          = canonical_url | split: '.com' | last
  assign curTemplate      = template | handleize

  comment 
    OVERLAY HEADER 
  endcomment

  assign assignments                = s.overlay_header_template
  assign useOverlay                 = false
  if assignments != blank 
    assign items                    = assignments | newline_to_br | split: '<br />'
    for item in items
      if item contains '/'
        assign url                  = item | trim | strip_newlines
        if url == curPage
          assign useOverlay         = true
          break
        endif
      else
        assign temp                 = item | handleize
        if temp == curTemplate
          assign useOverlay         = true
          break
        endif
      endif
    endfor
  endif 


  comment 
    DESKTOP - AT TOP  
  endcomment
  
  assign assignments                = s.desktop_at_top_black_bg
  assign desktopAtTop               = false
  if assignments != blank 
    assign items                    = assignments | newline_to_br | split: '<br />'
    for item in items
      if item contains '/'
        assign url                  = item | trim | strip_newlines
        if url == curPage
          assign desktopAtTop       = true
          break
        endif
      else
        assign temp                 = item | handleize
        if temp == curTemplate
          assign desktopAtTop       = true
          break
        endif
      endif
    endfor
  endif 

  assign assignments                = s.desktop_at_top_black_text
  assign desktopAtTopText           = false
  if assignments != blank 
    assign items                    = assignments | newline_to_br | split: '<br />'
    for item in items
      if item contains '/'
        assign url                  = item | trim | strip_newlines
        if url == curPage
          assign desktopAtTopText   = true
          break
        endif
      else
        assign temp                 = item | handleize
        if temp == curTemplate
          assign desktopAtTopText   = true
          break
        endif
      endif
    endfor
  endif 


  comment 
    DESKTOP - ON SCROLL  
  endcomment
  
  assign assignments                = s.desktop_on_scroll_black_bg
  assign desktopOnScroll            = false
  if assignments != blank 
    assign items                    = assignments | newline_to_br | split: '<br />'
    for item in items
      if item contains '/'
        assign url                  = item | trim | strip_newlines
        if url == curPage
          assign desktopOnScroll    = true
          break
        endif
      else
        assign temp                 = item | handleize
        if temp == curTemplate
          assign desktopOnScroll    = true
          break
        endif
      endif
    endfor
  endif 


  comment 
    MOBILE - AT TOP  
  endcomment
  
  assign assignments                = s.mobile_at_top_white_bg
  assign mobileAtTop                = false
  if assignments != blank 
    assign items                    = assignments | newline_to_br | split: '<br />'
    for item in items
      if item contains '/'
        assign url                  = item | trim | strip_newlines
        if url == curPage
          assign mobileAtTop        = true
          break
        endif
      else
        assign temp                 = item | handleize
        if temp == curTemplate
          assign mobileAtTop        = true
          break
        endif
      endif
    endfor
  endif 


  comment 
    MOBILE - ON SCROLL  
  endcomment
  
  assign assignments                = s.mobile_on_scroll_white_bg
  assign mobileOnScroll             = false
  if assignments != blank 
    assign items                    = assignments | newline_to_br | split: '<br />'
    for item in items
      if item contains '/'
        assign url                  = item | trim | strip_newlines
        if url == curPage
          assign mobileOnScroll     = true
          break
        endif
      else
        assign temp                 = item | handleize
        if temp == curTemplate
          assign mobileOnScroll     = true
          break
        endif
      endif
    endfor
  endif 

  assign largeHide        = 'large'
  assign smallHide        = 'medium'

  assign imgCSS           = ''

%}

{% for block in section.blocks %}
  {% liquid 
    assign b    = block.settings
    assign img  = b.image
    assign lnk  = b.title | handleize
    assign par  = b.parent | handleize
  %}
  {% if lnk != '' and img != '' %}
    {% capture imgCSS %}
      {{imgCSS}}
      [data-nav-item="{{par}}"]:hover [data-inner-nav-item="{{lnk}}"]::after {
        content:'';
        background-image: url({{img|img_url:'master'}});
      }
    {% endcapture %}
  {% endif %}
{% endfor %}
{% if imgCSS != '' %}
  {% assign customCSS = imgCSS | append: customCSS %}
{% endif %}

{% if useOverlay %}
  <script type="text/javascript" async>
    document.body.classList.add('overlay-header');
  </script>
{% endif %}


{% include 'header-style' %}


<style>
