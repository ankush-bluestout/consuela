          },
          {
            "type": "text",
            "id": "placement",
            "label": "Placement",
            "info": "'5' places the Ad before the 5th product."
          },
          {
            "type": "checkbox",
            "id": "after",
            "label": "Places ad after product instead."
          }, {
            "type": "textarea",
            "id": "show_on_collection",
            "label": "Show on Collections",
            "info": "Type in the url after '.com'. Ex: '\/collections\/all'. You can add multiple separated by commas."
          }, {
            "type": "textarea",
            "id": "exclude_from_collection",
            "label": "Exclude from Collections",
            "info": "Type in the url after '.com'. Ex: '\/collections\/all'. You can add multiple separated by commas."
          }, {
            "type": "header",
            "content": "CTA"
          }, {
            "type": "text",
            "id": "content_title",
            "label": "Title"
          }, {
            "type": "textarea",
            "id": "text",
            "label": "Text"
          }, {
            "type": "text",
            "id": "btn_text",
            "label": "Button Text"
          }, {
            "type": "url",
            "id": "btn_url",
            "label": "Button Url"
          }, {
            "type": "header",
            "content": "Image / Color Rules"
          }, {
            "type": "image_picker",
            "id": "bg_image",
            "label": "Background Image"
          }, {
            "type": "color",
            "id": "text_color",
            "label": "Text Color",
            "default": "#000000"
          }, {
            "type": "color_background",
            "id": "gradient",
            "label": "Gradient Background"
          }, {
            "type": "select",
            "id": "btn_style",
            "label": "Button Type",
            "info": "Button will only show if Button Text and Link are used, and videos are not used.",
            "options": [
              {
                "value": "primary",
                "label": "Primary"
              }, {
                "value": "secondary",
                "label": "Secondary"
              }, {
                "value": "arrow-link",
                "label": "Arrow Link"
              }
            ],
            "default": "primary"
          }, {
            "type": "header",
            "content": "Custom CSS Rules"
          }, {
            "type": "paragraph",
            "content": "Explanation of Custom CSS rules below input."
          }, {
            "type": "liquid",
            "id": "custom_css",
            "label": "Custom CSS"
          }, {
            "type": "paragraph",
            "content": "Use '==' to reference this block's parent container, that way the css you use only applies to this container. The example below applies font size to only the h2 element in the current block's container."
          }, {
            "type": "paragraph",
            "content": "Ex: '== h2 { font-size: 20px; }'"
          }, {
            "type": "paragraph",
            "content": "Use '/MEDIA_QUERY/' to create media queries that match css defaults. The example below would output '@media screen and (max-width: 749px)' before the css."
          }, {
            "type": "paragraph",
            "content": "Ex: '/small/ { == h2 { font-size: 20px; } }'"
