{% if template.suffix == 'variants' %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const labels = document.querySelectorAll('label');
      const placement = document.querySelector('#placement-1763759292387');

      if (placement) {
        labels.forEach((label) => {
          label.addEventListener('click', () => {
            placement.style.display = 'block'; // Force it to display
          });
        });
      }

      // Inject CSS inside Afterpay shadowRoot
      function injectStyle(shadowRoot) {
        if (!shadowRoot || shadowRoot.querySelector('style[data-custom-style]')) return;

        const style = document.createElement('style');
        style.dataset.customStyle = 'true';
        style.textContent = `
      @media (max-width: 425px) {
        .afterpay-logo-link {
          display: none !important;
        }

        .afterpay-main-text {
          font-size: 13px !important;
          top: 399px;
        }

        .afterpay-paragraph {
          position: absolute;
          margin-top: 312px;
        }
      }

      @media (max-width: 375px) {
        .afterpay-main-text {
          bottom: 70% !important;
        }
      }

      @media (max-width: 364px) {
        .afterpay-main-text {
          font-size: 12px !important;
        }
      }
    `;
        shadowRoot.appendChild(style);
        console.log('✅ Afterpay custom style injected');
      }
      function applyCustomStyle() {
        const targetSelector = 'square-placement';
        const el = document.querySelector(targetSelector);
        if (el && el.shadowRoot) {
          injectStyle(el.shadowRoot);
        } else {
          setTimeout(() => {
            const elRetry = document.querySelector(targetSelector);
            if (elRetry && elRetry.shadowRoot) injectStyle(elRetry.shadowRoot);
          }, 600);
        }
      }
      const observer = new MutationObserver(() => applyCustomStyle());
      observer.observe(document.body, { childList: true, subtree: true });
      applyCustomStyle();
      const variantLabels = document.querySelectorAll('.form__variants input');
      variantLabels.forEach((label) => {
        label.addEventListener('click', () => {
          window.location.href;
        });
      });
    });
  </script>
