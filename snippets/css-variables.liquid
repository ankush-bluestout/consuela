<script type="text/javascript" async>

  document.addEventListener('DOMContentLoaded', function () {

    setTimeout(function (argument) {
      document.body.classList.add('site-loaded');
    },100)

    updateHeightVar('#shopify-section-header', '--header-height')
    updateHeightVar('#shopify-section-announcement-bar', '--announce-height')
    
    {% unless isEditor %}
    // disables duplicate css link files.
    function removeDuplicateStyles() {
      var cssNodes    = document.getElementsByTagName("link"),
          foundNodes  = [],
          splitFirst  = 'assets/',
          splitLast   = '.css';
      for (const element of cssNodes) {
        var el        = element,
            elHref    = el.href,
            lnk       = elHref.split(splitFirst).pop().split(splitLast)[0];
        if (elHref.includes(splitFirst)) {
          if (foundNodes.includes(lnk)) {
            el.setAttribute('disabled', true);
          } else {
            foundNodes.push(lnk);
          }
        }
      }
    }
    removeDuplicateStyles()
    {% endunless %}

  })

  function updateHeightVar(el, v) {
    var prevH = 0;
    var rerunHeight = 400; // arbitrary setting for now. prevents broken looking pages.
    var itm = document.querySelector(el);

    initH()
    setTimeout(function() {
      initH(true)
    }, 100);
    window.addEventListener('resize', initH);
    window.addEventListener('scroll', initH);

    function initH(force) {
      var H = itm.clientHeight;
      if ( H > rerunHeight ) {
        setTimeout(function() {
          initH()
        }, 100);
      } else if (H != prevH || force == true) {
        // console.log('run') 
        // Then we set the value in the --header-height custom property to the root of the document
        document.documentElement.style.setProperty(v, `${H}px`);
        prevH = H;
      }
    }
  }



  function fixOphanedText(node) {
    const type          = node.nodeType,
      data              = typeof node.data !== 'undefined' ? node.data.trim() : '',
      minCharLength     = 15,
      minWords          = 3,
      validElements     = ['h1','h2','h3','h4','h5','h6','p','li','span','a','td','strong','b'],
      invalidElements   = ['NOSCRIPT','SCRIPT','STYLE','SVG'],
      skipClass         = 'skip-orphan-fix',
      notAlone          = data.length > minCharLength,
      skipElement       = !invalidElements.includes(node.nodeName.toUpperCase()),
      isText            = type == 3,
      isElement         = type == 1,
      textFound         = isText && skipElement && notAlone,
      goToNextChild     = isElement && skipElement;
    if (textFound) {
      var par           = node.parentNode,
          parType       = par.nodeName.toLowerCase(),
          parHTML       = par.innerHTML,
          parClasses    = par.classList,
          nodeLength    = data.split(' ').length;
      if ( (validElements.includes(parType) || parClasses.contains('rte') ) && nodeLength >= minWords && !parClasses.contains(skipClass) ) {
        // par.innerHTML = par.innerHTML.replace(/\s([^\s<]+)\s*$/,'&nbsp;$1');
        par.innerHTML = par.innerHTML.replace(/\s([^\s<]{0,15})\s*$/,'&nbsp;$1'); //{0,15} excludes longer words longer than 15 characters      
      }
    }
    if (goToNextChild) {
      for (var i = 0; i < node.childNodes.length; i++) {
        fixOphanedText(node.childNodes[i]);
      }
    }
  }
  window.addEventListener('DOMContentLoaded', (event) => {
    fixOphanedText(document.body);
    // fixOphanedText(document.getElementById('shopify-section-template--14680283643958__16618340269df8f1d8'));
  });

</script>



