{{ 'color-pattren-groups.css' | asset_url |  stylesheet_tag }}

{% assign colorProducts = product.metafields.custom.products_color_group.value %}

<div class="product__colors-group-wrapper" role="list">
  {% assign colorIndex = 1 %}
  {% for colorProduct in colorProducts %}
    {% assign is_current = false %}
    {% if colorProduct.url == product.url %}
      {% assign is_current = true %}
    {% endif %}
    {% if colorProduct.available == true %}
      <a 
        href="{{ colorProduct.url }}" 
        class="product__colors-item product__colors-item--{{ colorIndex }}{% if is_current %} product__colors-item--current{% endif %}{% if colorProduct.available == false %} product__colors-item--sold-out{% endif %}"
        role="listitem"
        aria-label="View {{ colorProduct.title }} color variant"
        {% if is_current %} aria-current="true" {% endif %}
      >
        <span class="visually-hidden">
          {{ colorProduct.title }} color variant
        </span>
        {% assign colorPattrenObject = colorProduct.metafields.custom.product_color_pattren.value %}
        {% for color in colorPattrenObject %}
          <img 
            src="{{ color.color_image | image_url: width: 80, height: 80 }}" 
            alt="{{ color.color_name }} color swatch"
            width="90"
            height="90"
            loading="lazy"
            class="product__colors-item-media"
          />
        {% endfor %}
      </a>
      {% assign colorIndex = colorIndex | plus: 1 %}
    {% endif %}
  {% endfor %}
</div>