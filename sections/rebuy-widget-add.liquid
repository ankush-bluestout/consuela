{% schema %}
  {
    "name": "Rebuy Widget Add",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "checkbox",
        "id": "widget_theme_type",
        "label": "Widget Theme (Black : recommend)",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_title",
        "label": "Show info",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_ATC",
        "label": "Show ATC",
        "default": true
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Rebuy id",
        "settings": [
          {
            "type": "text",
            "id": "rebuy_name",
            "label": "Rebuy Name"
          },
          {
            "type": "checkbox",
            "id": "show_title",
            "label": "Show Title",
            "default": true
          },
          {
            "type": "text",
            "id": "id",
            "label": "Rebuy Id"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Rebuy Widget Add"
      }
    ]
  }
{% endschema %}