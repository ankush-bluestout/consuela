        "title": "",
        "custom_html": "{%- liquid\n  assign mf         = article.metafields.custom\n  assign loc        = mf.location\n  assign qte        = mf.quote\n-%}\n\n<div class=\"page-width\">\n  <div class=\"cell cell_margin_bottom vert-top text-center\">\n    <div class=\"cell__item medium-up--one-half text-left quote-container\">\n      {% if qte != blank %}\n        {% render 'icon-quote' %}\n        <div class=\"rte\">{{qte}}</div>\n      {% endif %}\n    </div> \n    <div class=\"cell__item medium-up--one-half text-left\">\n      {{article.content}}\n    </div>\n  </div>\n</div>",
        "custom_css": "== {\n  padding: var(--base-gutter) 0;\n}\n\n== .page-width {\n  max-width: 1200px;\n  padding: 0 var(--base-gutter);\n}\n\n\n== .quote-container {\n  font-family: var(--font--graphik-cond);\n  font-weight: 700;\n  font-size: 48px;\n  text-align: center;\n  position: relative;\n  line-height: 1.1;\n}\n\n== svg {\n  position: absolute;\n  top: 0%;\n  left: var(--grid-gutter);\n  transform: translate(-40%,-40%);\n  width: var(--base-gutter--double);\n  height: var(--base-gutter--double);\n  color: var(--color--turbo-yellow);\n  z-index: -1;\n}\n\n\n\n/medium-up/ {\n  == {\n    padding: var(--base-gutter--half) 0;\n  }\n  == .cell {\n    --grid-gutter: var(--base-gutter--double);\n  }\n  == .quote-container {\n     margin-top: 25%;\n  }\n}\n\n/large-up/ {\n  == {\n    padding: var(--base-gutter) 0;\n  }\n  == .cell {\n    --grid-gutter: var(--base-gutter--trip);\n  }\n  == .quote-container {\n    font-size: 72px;\ntext-transform: uppercase;\n  }\n}"
